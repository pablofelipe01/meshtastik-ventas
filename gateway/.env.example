# ---- Gateway mesh portátil: variables de entorno ----
# Copia a .env y rellena. El .env NO se commitea.

# Radio Meshtastic por serial. Vacío = autodetección (recomendado).
MESH_SERIAL_PORT=

# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---- Anthropic / @claude ----
ANTHROPIC_API_KEY=sk-ant-REEMPLAZAME
CLAUDE_MODEL=claude-haiku-4-5
CLAUDE_MAX_TOKENS=160
CLAUDE_TIMEOUT=30
# Personalidad/reglas de Claude en la mesh (respuestas cortas, en español).
CLAUDE_SYSTEM_PROMPT=Eres un asistente para una red de radio de texto (Meshtastic/LoRa) en zonas sin internet. Respondes SIEMPRE en español, de forma breve, completa y directa, en menos de 350 caracteres. Termina siempre con punto final.
