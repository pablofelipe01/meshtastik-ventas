# ---- Gateway mesh portátil: variables de entorno ----
# Copia a .env y rellena. El .env NO se commitea.

# Radio Meshtastic por serial. Vacío = autodetección (recomendado).
MESH_SERIAL_PORT=

# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---- Anthropic / @claude ----
ANTHROPIC_API_KEY=sk-ant-REEMPLAZAME
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1024
CLAUDE_TIMEOUT=60
# Personalidad/reglas de Claude en la mesh (asistente general, respuestas cortas).
CLAUDE_SYSTEM_PROMPT=Eres un asistente general útil que responde por una red de radio de texto (Meshtastic/LoRa) en zonas sin internet. Puedes responder sobre CUALQUIER tema. Cuando la pregunta dependa de datos actuales (noticias, precios, clima, eventos, resultados deportivos), usa la búsqueda web. Responde SIEMPRE en español, de forma breve, completa y directa, en menos de 350 caracteres. Termina siempre con punto final.

# ---- Búsqueda web (deja que Claude busque en internet; cuesta ~$10/1000 búsquedas) ----
CLAUDE_WEB_SEARCH=true
CLAUDE_WEB_SEARCH_MAX_USES=5

# ---- Memoria de conversación por nodo ----
# Cada teléfono mantiene su propio hilo; los seguimientos ("y el viernes?")
# funcionan. Se olvida tras TTL minutos de inactividad. "@claude nuevo" reinicia.
CLAUDE_MEMORY=true
CLAUDE_MEMORY_TTL_MIN=5
CLAUDE_MEMORY_MAX_TURNS=8

# ---- Puente mesh↔internet (familia) vía Supabase ----
# Con estas dos variables se activa el puente: un DM al gateway (que no sea
# @claude) va a la familia; los mensajes de la familia se entregan por la mesh.
# La SERVICE_KEY es el secreto service_role de Supabase (Settings > API).
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=REEMPLAZAME_service_role
BRIDGE_POLL_SECONDS=4
BRIDGE_NODE_SYNC_SECONDS=45

# ---- Envío de correos desde la mesh (herramienta @claude "enviar_correo") ----
# Con SMTP configurado, @claude puede mandar correos. Ej. Fastmail:
#   SMTP_HOST=smtp.fastmail.com  SMTP_PORT=465 (SSL) o 587 (STARTTLS)
#   SMTP_USER=tucorreo@fastmail.com  SMTP_PASSWORD=<app password de Fastmail>
# Los alias de destinatario se resuelven en la libreta (tabla email_contacts).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ---- Módulo Campo: captura agroindustrial (@ag|...) ----
# A qué CLIENTE sirve este gateway (id de la tabla campo_clientes). Obligatorio:
# el gateway escribe con service_role, que salta las políticas RLS, así que es él
# quien estampa el cliente en cada captura y quien filtra su catálogo. Sin esto,
# el módulo Campo no arranca.
CAMPO_CLIENTE_ID=
# El espejo a Airtable es
# opcional: sin token, las capturas igual se guardan en Supabase.
# El token de Airtable debe ser un PAT con acceso SOLO a la base de la demo
# (scopes: data.records:read, data.records:write, schema.bases:read).
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_ID=
CAMPO_CATALOG_REFRESH_SECONDS=300
CAMPO_FLUSH_SECONDS=5
CAMPO_AIRTABLE_SECONDS=10
